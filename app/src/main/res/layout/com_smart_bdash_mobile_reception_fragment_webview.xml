<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="240dp"
    android:id="@+id/com_smart_bdash_mobile_rootView"
    >
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:id="@+id/com_smart_bdash_mobile_reception_webViewFrame"
        android:layout_gravity="top|center_horizontal"
    >
        <!-- ここの View Size は何でも良い. Code で調整する-->
        <View
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:layout_gravity="top|left"
            />
        <WebView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_gravity="top|left"
            android:id="@+id/com_smart_bdash_mobile_reception_webView"
            />
        <!-- ここまでCodeで調整-->
    </LinearLayout>

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/com_smart_bdash_mobile_close_100x100"
        android:scaleType="fitCenter"
        android:layout_gravity="top|right"
        android:visibility="gone"
        android:id="@+id/com_smart_bdash_mobile_reception_closeButton"/>

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:scaleType="fitCenter"
        android:layout_gravity="top|left"
        android:visibility="gone"
        android:id="@+id/com_smart_bdash_mobile_reception_closeButton_adjustable"/>
</FrameLayout>
